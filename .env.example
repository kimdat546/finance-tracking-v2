# ============================================================================
# Personal Finance Tracker - Environment Configuration
# ============================================================================
# Copy this file to .env and configure values for your environment
# WARNING: Never commit the actual .env file with production secrets to git
# ============================================================================

# ============================================================================
# Application Configuration
# ============================================================================
APP_ENV=dev
DEBUG=true
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256

# ============================================================================
# Database Configuration
# ============================================================================
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=finance_password
POSTGRES_DB=finance_db
DATABASE_URL=postgresql+asyncpg://finance_user:finance_password@postgres:5432/finance_db

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_PASSWORD=redis_password
REDIS_URL=redis://:redis_password@redis:6379/0

# ============================================================================
# Frontend Configuration
# ============================================================================
REACT_APP_API_BASE_URL=http://localhost:8000
REACT_APP_ENV=development

# ============================================================================
# Gmail Integration Configuration
# ============================================================================
GMAIL_CREDENTIALS_PATH=/secrets/credentials.json
GMAIL_TOKEN_PATH=/secrets/token.json
EMAIL_SYNC_INTERVAL_MINUTES=15
ENABLE_EMAIL_SYNC=true

# ============================================================================
# CORS Configuration
# ============================================================================
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# ============================================================================
# Backup Configuration
# ============================================================================
BACKUP_DIR=/var/backups/finance-tracker
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_KEY=

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_EMAIL_SYNC=true
ENABLE_SCHEDULER=true
ENABLE_PARSER_AUTO_DISCOVERY=true

# ============================================================================
# Nginx / Reverse Proxy Configuration (Production)
# ============================================================================
DOMAIN=localhost
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=1024

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
